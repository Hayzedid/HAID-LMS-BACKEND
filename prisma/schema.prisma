generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------
// Users & Auth
// ----------------------------------------------------
enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
  HR_MANAGER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  firstName String
  lastName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Analytics & Retention
  currentStreak      Int             @default(0)
  longestStreak      Int             @default(0)
  lastActivityDate   DateTime?
  healthScore        Int             @default(0) // 0-100 analytics based

  organizationId     String?
  departmentId       String?
  groupId            String?

  // Relations
  organization       Organization?   @relation(fields: [organizationId], references: [id])
  department         Department?     @relation(fields: [departmentId], references: [id])
  group              Group?          @relation(fields: [groupId], references: [id])
  coursesTaught      Course[]        @relation("InstructorCourses")
  ideSubmissions     IDESubmission[]
  videoSessions      VideoSession[]
  proctoringSessions ProctoringSession[]
  scheduledReviews   ScheduledReview[]
  certificates       Certificate[]
  transactions       Transaction[]
  notifications      Notification[]
  githubIntegration  GitHubIntegration?
  externalProjects   ExternalProject[]

  // Phase 8 Governance & Security
  mfaEnabled         Boolean         @default(false)
  ssoProvider        String?         // e.g., GOOGLE, GITHUB
  outcomeScore       Float           @default(0.0)
  learningPaths      LearningPathAssignment[]
  assignedInvites    UserInvite[]    @relation("InvitedByUser")
  receivedInvite     UserInvite?     @relation("InvitedUser")
  lessonCompletions  LessonCompletion[]
}

// ----------------------------------------------------
// Course Management
// ----------------------------------------------------
model Course {
  id           String   @id @default(uuid())
  title        String
  description  String
  level        String   // e.g., Beginner, Intermediate, Advanced
  instructorId String
  organizationId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  instructor   User     @relation("InstructorCourses", fields: [instructorId], references: [id])
  modules      Module[]
  certificates Certificate[]
  externalProjects ExternalProject[]
  learningPaths    LearningPathCourse[]
}

model Module {
  id        String   @id @default(uuid())
  title     String
  order     Int
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
}

enum LessonType {
  VIDEO
  TEXT
  CODE
  AUDIO
}

model Lesson {
  id          String     @id @default(uuid())
  title       String
  type        LessonType
  content     String?    @db.Text // Support long-form typed content
  videoUrl    String?    // If VIDEO
  audioUrl    String?    // If AUDIO
  attachmentUrl String?  // Optional supplemental file
  order       Int
  moduleId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  module          Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  ideSubmissions  IDESubmission[]
  videoSessions   VideoSession[]
  checkpoints     CheckpointQuiz[]
  proctoredExam   ProctoredExam?
  scheduledReviews ScheduledReview[]
  completions      LessonCompletion[]
}

// ----------------------------------------------------
// Video & Engagement Accountability
// ----------------------------------------------------
model VideoSession {
  id                    String   @id @default(uuid())
  accumulatedWatchTime  Int      @default(0) // In seconds
  completed             Boolean  @default(false)
  studentId             String
  lessonId              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  student   User     @relation(fields: [studentId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  events    VideoEvent[]
}

model VideoEvent {
  id             String   @id @default(uuid())
  type           String   // e.g., TAB_UNFOCUSED, PAUSED, SEEKED
  timestamp      Int      // Video timestamp in seconds
  videoSessionId String
  createdAt      DateTime @default(now())

  videoSession   VideoSession @relation(fields: [videoSessionId], references: [id])
}

model LessonCompletion {
  id        String   @id @default(uuid())
  studentId String
  lessonId  String
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  student   User     @relation(fields: [studentId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([studentId, lessonId])
}

model CheckpointQuiz {
  id        String   @id @default(uuid())
  question  String
  answer    String
  timestamp Int      // Second mark the quiz triggers
  lessonId  String
  createdAt DateTime @default(now())

  lesson    Lesson   @relation(fields: [lessonId], references: [id])
}

// ----------------------------------------------------
// IDE & Integrity
// ----------------------------------------------------
model IDESubmission {
  id        String   @id @default(uuid())
  language  String   // e.g., python, js
  code      String   @db.Text
  status    String   // e.g., PENDING, PASSED, FAILED, FLAGGED
  
  studentId String
  lessonId  String
  vivaUrl   String?  // URL to screen-recorded video explanation
  createdAt DateTime @default(now())

  student   User     @relation(fields: [studentId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  
  keystrokes KeystrokeSession[]
  flags      IntegrityFlag[]
}

model KeystrokeSession {
  id              String   @id @default(uuid())
  submissionId    String
  payload         String   @db.Text // Serialized JSON array of keystroke events
  createdAt       DateTime @default(now())

  submission      IDESubmission @relation(fields: [submissionId], references: [id])
}

model IntegrityFlag {
  id                  String   @id @default(uuid())
  type                String   // e.g., COPY_PASTE_ATTEMPT, AI_SIGNATURE_DETECTED, PROCTORING_VIOLATION
  description         String?
  submissionId        String?
  proctoringSessionId String?
  createdAt           DateTime @default(now())

  submission          IDESubmission?     @relation(fields: [submissionId], references: [id])
  proctoringSession   ProctoringSession? @relation(fields: [proctoringSessionId], references: [id])
}

// ----------------------------------------------------
// Assessments & Proctoring
// ----------------------------------------------------
model ProctoredExam {
  id              String   @id @default(uuid())
  title           String
  description     String?
  durationMinutes Int
  passingScore    Int
  lessonId        String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lesson          Lesson   @relation(fields: [lessonId], references: [id])
  sessions        ProctoringSession[]
}

model ProctoringSession {
  id               String   @id @default(uuid())
  studentId        String
  examId           String
  status           String   // e.g., STARTED, COMPLETED, FLAGGED, TERMINATED
  startTime        DateTime @default(now())
  endTime          DateTime?
  
  // Integrity metadata
  webcamEnabled    Boolean  @default(false)
  screenSharing    Boolean  @default(false)
  identityVerified Boolean  @default(false)
  riskScore        Int      @default(0) // 0-100

  student          User          @relation(fields: [studentId], references: [id])
  exam             ProctoredExam @relation(fields: [examId], references: [id])
  flags            IntegrityFlag[]
}

// ----------------------------------------------------
// Retention & Certification (Phase 4)
// ----------------------------------------------------
model ScheduledReview {
  id          String   @id @default(uuid())
  studentId   String
  lessonId    String
  reviewDate  DateTime
  interval    Int      @default(1) // In days
  easeFactor  Float    @default(2.5)
  reviewedCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     User     @relation(fields: [studentId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([studentId, lessonId])
}

model Certificate {
  id          String   @id @default(uuid())
  studentId   String
  courseId    String
  issueDate   DateTime @default(now())
  pdfUrl      String
  badgeUrl    String?
  metadata    Json?    // Open Badges 2.0 compliant data

  student     User     @relation(fields: [studentId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  studentId   String
  amount      Float
  currency    String   // e.g., NGN, USD
  provider    String   // e.g., PAYSTACK, FLUTTERWAVE, STRIPE
  status      String   // e.g., SUCCESS, FAILED, PENDING
  reference   String   @unique
  createdAt   DateTime @default(now())

  student     User     @relation(fields: [studentId], references: [id])
}

// ----------------------------------------------------
// Enterprise & Notifications (Phase 5)
// ----------------------------------------------------
model Department {
  id             String   @id @default(uuid())
  name           String   @unique
  organizationId String?
  createdAt      DateTime @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id])
  users          User[]
  groups         Group[]
}

model Group {
  id           String   @id @default(uuid())
  name         String
  departmentId String
  createdAt    DateTime @default(now())

  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // e.g., SRS_REMINDER, INTEGRITY_FLAG, PAYMENT_SUCCESS
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ----------------------------------------------------
// Multi-Tenancy (Phase 6)
// ----------------------------------------------------
model Organization {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String?
  themeConfig Json?    // { primaryColor: string, secondaryColor: string }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  courses     Course[]
  departments Department[]
  learningPaths LearningPath[]
  invites     UserInvite[]

  // Phase 8 Management
  seatLimit   Int           @default(10)
  usedSeats   Int           @default(0)
}

model GitHubIntegration {
  id               String   @id @default(uuid())
  userId           String   @unique
  githubUsername   String
  accessToken      String   // Encrypted in production
  refreshToken     String?
  tokenExpiresAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
}

model ExternalProject {
  id             String   @id @default(uuid())
  userId         String
  courseId       String
  repoUrl        String
  branch         String   @default("main")
  lastSyncAt     DateTime?
  integrityScore Int?     // Result of AI code analysis
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
  course         Course   @relation(fields: [courseId], references: [id])
}

// ----------------------------------------------------
// Enterprise Governance (Phase 8)
// ----------------------------------------------------
model LearningPath {
  id             String   @id @default(uuid())
  name           String
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  courses        LearningPathCourse[]
  assignments    LearningPathAssignment[]
}

model LearningPathCourse {
  learningPathId String
  courseId       String
  order          Int      // Sequence of courses

  learningPath   LearningPath @relation(fields: [learningPathId], references: [id])
  course         Course       @relation(fields: [courseId], references: [id])

  @@id([learningPathId, courseId])
}

model LearningPathAssignment {
  id             String   @id @default(uuid())
  userId         String
  learningPathId String
  status         String   @default("IN_PROGRESS")
  deadline       DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id])
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id])
}

model UserInvite {
  id             String   @id @default(uuid())
  email          String
  organizationId String
  role           Role     @default(STUDENT)
  invitedById    String
  status         String   @default("PENDING")
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  acceptedUserId String?  @unique

  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedBy      User         @relation("InvitedByUser", fields: [invitedById], references: [id])
  acceptedUser   User?        @relation("InvitedUser", fields: [acceptedUserId], references: [id])
}
